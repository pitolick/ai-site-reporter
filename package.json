{
  "name": "@pitolick/ai-site-reporter",
  "version": "0.0.0",
  "private": true,
  "description": "サイト分析・改善提案の汎用 TypeScript ライブラリ",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.10.0",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.5",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
